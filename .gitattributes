* text=auto eol=lf

# Generated ARM template — always LF to match `bicep build` output on Linux CI
infra/main.json text eol=lf

# Bicep sources
*.bicep      text eol=lf
*.bicepparam text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.ps1 text eol=crlf
*.cmd text eol=crlf

# Binary
*.zip binary
*.png binary
*.jpg binary
*.pdf binary
